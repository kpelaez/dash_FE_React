# =============================================================================
# StoneFixer Frontend — Variables de entorno
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copiá este archivo:
#        cp .env.example .env.development   ← para desarrollo local
#        cp .env.example .env.production    ← para producción
#   2. Completá los valores según el entorno
#   3. NUNCA commitees .env, .env.development ni .env.production
#      (ya están en .gitignore)
#
# Vite expone solo las variables con prefijo VITE_ al navegador.
# Las variables sin ese prefijo son privadas al proceso de build.
# =============================================================================

# -----------------------------------------------------------------------------
# API — URL base del backend FastAPI
# -----------------------------------------------------------------------------
# Desarrollo local:
VITE_API_URL=http://localhost:8000

# Producción:
# VITE_API_URL=https://stonefixer.mklcoders.com.ar

# -----------------------------------------------------------------------------
# Entorno (informativo, no afecta el comportamiento de Vite)
# -----------------------------------------------------------------------------
# Vite ya expone import.meta.env.MODE automáticamente ('development' | 'production')
# Esta variable es solo para referencia en logs o documentación.
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# Nombre de la app (usado en títulos, meta tags, etc.)
# -----------------------------------------------------------------------------
VITE_APP_NAME=StoneFixer

# -----------------------------------------------------------------------------
# Feature flags (opcionales)
# -----------------------------------------------------------------------------
# Activar datos mock para desarrollo sin backend disponible.
# Usar 'true' solo en .env.development, nunca en producción.
VITE_USE_MOCK=false
